#!/bin/bash
# Color-Coded Daily Bread (No HTML)
VERSE=$(curl -s "https://labs.bible.org/api/?passage=random&type=text")

if [ -n "$VERSE" ]; then
    # Strip HTML, Split on Verse Reference, Apply Cyan/White
    echo "$VERSE" | sed -e 's/<b>//g' -e 's/<\/b>//g' | \
    sed -E 's/^([^0-9]* [0-9]+:[0-9]+) (.*)/\1|\2/' | \
    awk -F'|' '{printf "\033[1;36m%s\033[0m\n\033[1;37m%s\033[0m\n", $1, $2}' | \
    fold -s -w 60
fi
